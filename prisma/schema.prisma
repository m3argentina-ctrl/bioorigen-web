generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  price       Float
  salePrice   Float?
  stock       Int
  category    String
  linea       String?
  featured    Boolean  @default(false)
  images      String[]
  specs       Json?
  dataSheet   String?
  videoUrl    String?
  weightGrams Int?
  heightCm    Float?
  widthCm     Float?
  lengthCm    Float?
  rating      Float?
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recipe {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  emoji       String   @default("🌿")
  description String   @db.Text
  category    String
  difficulty  String
  time        String
  temperature String
  ingredients String[]
  equipment   String[]
  steps       String[]
  variations  String[]
  uses        String[]
  image       String   @default("")
  images      String[]
  featured    Boolean  @default(false)
  season      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  description String?  @db.Text
  image       String
  buttonText  String?
  buttonLink  String?
  bgColor     String   @default("#4A7C59")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([active])
}

model ValueProp {
  id        String   @id @default(cuid())
  icon      String   @default("Sprout")
  title     String
  text      String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([active])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([active])
}

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model Order {
  id                 String   @id @default(cuid())
  customerEmail      String
  customerName       String
  customerPhone      String
  customerAddress    String   @db.Text
  items              Json
  subtotal           Float
  shipping           Float
  discount           Float    @default(0)
  total              Float
  status             String   @default("pending")
  paymentMethod      String   @default("mercadopago")
  mercadoPagoId      String?
  paymentStatus      String?
  shippingCarrier    String?
  shippingMethod     String?
  shippingIsFree     Boolean  @default(false)
  shippingFreeReason String?
  openpayId          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([customerEmail])
  @@index([status])
}

model PaymentConfig {
  id                   String   @id @default(cuid())
  bankTransferEnabled  Boolean  @default(false)
  bankTransferDiscount Int      @default(0)
  bankName             String   @default("")
  bankHolder           String   @default("")
  bankCbu              String   @default("")
  bankAlias            String   @default("")
  bankNote             String   @default("")
  openpayEnabled       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ShippingConfig {
  id                String   @id @default(cuid())
  andreaniEnabled   Boolean  @default(true)
  andreaniDomicilio Float    @default(13000)
  andreaniSucursal  Float    @default(11000)
  andreaniDays      String   @default("2-4 días")
  andreaniInsurance Boolean  @default(true)
  correoEnabled     Boolean  @default(true)
  correoDomicilio   Float    @default(19000)
  correoSucursal    Float    @default(16000)
  correoDays        String   @default("6-10 días")
  correoInsurance   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FreeShippingConfig {
  id            String    @id @default(cuid())
  enabled       Boolean   @default(true)
  name          String
  type          String    @default("minimum_amount")
  minimumAmount Float?
  campaignName  String?
  startDate     DateTime?
  endDate       DateTime?
  freeZipCodes  String[]  @default([])
  productIds    String[]  @default([])
  categories    String[]  @default([])
  couponCode    String?
  applyAndreani Boolean   @default(true)
  applyCorreo   Boolean   @default(true)
  priority      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  status    String   @default("unread")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ===========================================================================
// Telemetría de equipos FA-10T (monitoreo remoto multi-tenant) — fase 4 F1
// Cada equipo (deshidratador) queda fijo en la fábrica del cliente y empuja su
// estado por HTTPS a /api/telemetry/ingest. El cliente lo mira desde su casa;
// Bio Origen monitorea toda la flota. La ausencia de muestras = equipo caído.
// ===========================================================================

// Cliente dueño de uno o más equipos (tenant).
model Cliente {
  id             String   @id @default(cuid())
  nombre         String
  email          String?  @unique          // login / notificaciones
  telegramChatId String?                    // destino de alertas Telegram (F3)
  notas          String?
  equipos        Equipo[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Equipo físico. La identidad (deviceId + token) se pre-carga de fábrica en la
// partición NVS "factory" del ESP32 al flashear (ver firmware tools/provision).
model Equipo {
  id        String  @id @default(cuid())
  deviceId  String  @unique               // dev_id de fábrica, ej "FA10T-0001"
  token     String                        // secreto Bearer (API key del equipo)
  nombre    String?                        // alias para el cliente
  modelo    String?                        // último reportado por el equipo
  serie     String?
  activo    Boolean @default(true)

  cliente   Cliente? @relation(fields: [clienteId], references: [id])
  clienteId String?

  // Cache del último reporte (para listar la flota sin escanear Muestra).
  lastSeenAt   DateTime?
  online       Boolean  @default(false)
  lastReason   String?
  lastRunState Int?
  lastTemp     Float?

  muestras  Muestra[]
  eventos   Evento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clienteId])
}

// Una muestra de telemetría (heartbeat o evento de estado). Espejo del JSON que
// arma el firmware en cloud_telemetry.c / web_server.c (/api/status).
model Muestra {
  id       String @id @default(cuid())
  equipo   Equipo @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  equipoId String

  reason   String                 // boot | state | alarm | heartbeat

  temp     Float
  rawTemp  Float?
  fault    Boolean @default(false)
  spEff    Float?
  spCfg    Float?
  drv      Float?                  // % duty 0..100
  fan      Float?
  aux      Float?
  hum      Float?
  humFault Boolean @default(false)

  opMode     Int?
  runState   Int?
  warmup     Boolean @default(false)
  etapa      Int?
  elapsedS   Int?
  totalS     Int?
  remainingS Int?
  tMin       Float?
  tMax       Float?
  prog       String?
  uptimeS    Int?

  createdAt DateTime @default(now())

  @@index([equipoId, createdAt])
}

// Evento accionable para alertas (alarma reportada por el equipo, u offline
// detectado por el watchdog de heartbeats del lado servidor — F3).
model Evento {
  id       String @id @default(cuid())
  equipo   Equipo @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  equipoId String

  kind       String                 // alarm | offline | online | boot | fault | service
  message    String?
  notified   Boolean   @default(false)  // si ya se mandó el aviso (Telegram)
  resolvedAt DateTime?                  // p.ej. offline cerrado al volver online
  createdAt  DateTime  @default(now())

  @@index([equipoId, createdAt])
  @@index([notified])
}
